@{
    ViewData["Title"] = "My Profile";
}

<h1>My Profile</h1>

<div class="profile-container">
    <h2>Profile Information</h2>
    <div class="profile-info">
        <p>
            <strong>User ID:</strong> 
            <span>@ViewBag.UserId</span>
        </p>
        <p>
            <strong>Email:</strong> 
            <span>@ViewBag.Email</span>
        </p>
    </div>
</div>
